name: 🐍 Generate Contribution Snake

on:
  schedule:
    - cron: "0 0 * * *"   # runs daily at midnight UTC
  workflow_dispatch:        # trigger manually from the Actions tab

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Snake Evolution
        uses: miccy/snake-evolution@v1.3.0
        with:
          github_user_name: jamiedevera
          github_token: ${{ secrets.GITHUB_TOKEN }}
          outputs: dist/github-contribution-grid-snake.svg
          theme: github-light   # 🌸 matches the Sakura palette nicely!
          # other theme options: github-dark, ocean, sunset, neon-gamer, cypherpunk

      - name: Deploy to output branch
        uses: crazy-max/ghaction-github-pages@v2
        with:
          target_branch: output
          build_dir: dist
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
